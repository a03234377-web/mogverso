{
  "rules": {
    ".read": true,
    ".write": false,

    "rankOverrides": {
      ".write": true
    },
    "rankMovements": {
      ".write": true
    },
    "rankMovementsUp": {
      ".write": true
    },
    "rankMovementsDown": {
      ".write": true
    },

    "rankvoteHistory": {
      "$roundId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['ts']) && newData.child('ts').isNumber()"
      }
    },

    "rankvoteVotes": {
      "$voteId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['candidate', 'ts']) && newData.child('ts').isNumber()"
      }
    },

    "rankvote": {
      "current": {
        ".write": true,
        "votes": {
          "$candidate": {
            ".write": "newData.isNumber() && (!data.exists() || newData.val() === data.val() + 1)"
          }
        }
      }
    },

    "entryVotes": {
      "$voteId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['candidate', 'ts']) && newData.child('ts').isNumber()"
      }
    },

    "entryVote": {
      "current": {
        ".write": true,
        "votes": {
          "$candidate": {
            ".write": "newData.isNumber() && (!data.exists() || newData.val() === data.val() + 1)"
          }
        }
      }
    },

    "torneoVotes": {
      ".write": true,
      "$voteId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['candidate', 'ts']) && newData.child('ts').isNumber()"
      }
    },

    "torneo": {
      "state": {
        ".write": true,
        "matches": {
          "$matchId": {
            "votes": {
              "$candidate": {
                ".write": "newData.isNumber() && (!data.exists() || newData.val() === data.val() + 1)"
              }
            }
          }
        },
        "cuartosMatches": {
          "$matchId": {
            "votes": {
              "$candidate": {
                ".write": "newData.isNumber() && (!data.exists() || newData.val() === data.val() + 1)"
              }
            }
          }
        },
        "semisMatches": {
          "$matchId": {
            "votes": {
              "$candidate": {
                ".write": "newData.isNumber() && (!data.exists() || newData.val() === data.val() + 1)"
              }
            }
          }
        },
        "finalMatch": {
          "votes": {
            "$candidate": {
              ".write": "newData.isNumber() && (!data.exists() || newData.val() === data.val() + 1)"
            }
          }
        }
      }
    }
  }
}
