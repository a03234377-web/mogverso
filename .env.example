# Firebase — copia a .env.local y rellena con tus credenciales
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google AdSense (opcional; solo en producción salvo dev explícito)
NEXT_PUBLIC_ADSENSE_CLIENT=
# NEXT_PUBLIC_ADSENSE_DEV=true

# reCAPTCHA v3 (site key pública; secret solo server-side abajo)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# URL pública (metadatos SEO)
NEXT_PUBLIC_SITE_URL=

# Legacy: bloquear clic derecho y algunos atajos en producción (no bloquea DevTools)
# NEXT_PUBLIC_ENABLE_SECURITY_GUARD=true

# --- Server-only (sin NEXT_PUBLIC_) — Route Handlers / Admin SDK ---
# JSON de cuenta de servicio Firebase en una línea
FIREBASE_SERVICE_ACCOUNT_JSON=
RECAPTCHA_SECRET_KEY=
ADMIN_SECRET=
# Vercel Cron: Authorization Bearer en /api/cron/* (middleware)
CRON_SECRET=

# Rate limit distribuido (opcional; sin esto usa memoria en dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Firebase App Check (opcional; site key distinta de reCAPTCHA v3 de votos)
# NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
